{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/website/index.html"
    },
    {
      "source": "/css/:path*",
      "destination": "/website/css/:path*"
    },
    {
      "source": "/js/:path*",
      "destination": "/website/js/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/website/assets/:path*"
    },
    {
      "source": "/:path((?!website/).*\\.html)",
      "destination": "/website/:path"
    },
    {
      "source": "/:path(.*\\.exe)",
      "destination": "/website/:path"
    },
    {
      "source": "/:path(.*\\.zip)",
      "destination": "/website/:path"
    },
    {
      "source": "/ciphercore_icon.ico",
      "destination": "/website/ciphercore_icon.ico"
    }
  ]
}
