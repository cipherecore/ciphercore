{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/website/index.html"
    },
    {
      "source": "/(css|js|assets|Output|Output/(.*))/(.*)",
      "destination": "/website/$1/$2"
    },
    {
      "source": "/(.*).html",
      "destination": "/website/$1.html"
    },
    {
      "source": "/(.*).exe",
      "destination": "/website/$1.exe"
    },
    {
      "source": "/(.*).zip",
      "destination": "/website/$1.zip"
    },
    {
      "source": "/(.*)",
      "destination": "/website/$1"
    }
  ]
}
